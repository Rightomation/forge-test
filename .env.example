# Copy to `.env` for local Forge / agent orchestrator (adjust names to match your script).

# --- LLM (Forge script scripts/forge_agents_v2.py uses Anthropic) ---
ANTHROPIC_API_KEY=
# Optional: model id if the default fails (see Anthropic docs)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=

# --- Git ---
GITHUB_TOKEN=
# GITHUB_REPO=owner/repo

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (optional; forge script accepts either set) ---
EMAIL_FROM=
EMAIL_TO=
EMAIL_PASSWORD=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# --- SSH / VPS deploy (optional) ---
# VPS_HOST=
# VPS_USER=
# SSH_KEY_PATH=

# --- Docker Compose (repo root `.env`; used at `docker compose build` for Next.js) ---
# URL the *browser* uses to call the API (your VPS IP or https://yourdomain.com)
# NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:8000
