# Copy to `.env` for local Forge / agent orchestrator (adjust names to match your script).

# --- LLM (use what your pipeline expects) ---
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Git ---
GITHUB_TOKEN=
# GITHUB_REPO=owner/repo

# --- Telegram (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (optional) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# --- SSH / VPS deploy (optional) ---
# VPS_HOST=
# VPS_USER=
# SSH_KEY_PATH=

# --- Docker Compose (repo root `.env`; used at `docker compose build` for Next.js) ---
# URL the *browser* uses to call the API (your VPS IP or https://yourdomain.com)
# NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:8000
