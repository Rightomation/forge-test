# Copy to backend/.env for local runs (uvicorn from backend/).
# Required — app will not start without these two:

# SQLite (simple local dev; DB file created next to cwd, usually backend/app.db)
DATABASE_URL=sqlite:///./app.db

# JWT signing — use a long random string in production (32+ chars)
SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-characters

# Optional (defaults match config.py if omitted):
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Postgres example (if you use PostgreSQL instead) ---
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/taskmanager
